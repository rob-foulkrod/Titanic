@model App.Web.Models.TodoItem

@{
    ViewData["Title"] = "Task Details";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="todo-card">
            <div class="todo-card-header d-flex justify-content-between align-items-center">
                <h2 class="h4 mb-0 fw-bold">👁 Task Details</h2>
                <span class="priority-badge priority-@Model.Priority.ToString().ToLower()">
                    @Model.Priority Priority
                </span>
            </div>
            <div class="p-4">
                <div class="mb-4">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <h3 class="h5 mb-0 @(Model.IsCompleted ? "text-decoration-line-through text-muted" : "")">
                            @Model.Title
                        </h3>
                        @if (Model.IsCompleted)
                        {
                            <span class="priority-badge" style="background: var(--todo-success-light); color: var(--todo-success)">✓ Done</span>
                        }
                        else
                        {
                            <span class="priority-badge" style="background: var(--todo-primary-light); color: var(--todo-primary)">Active</span>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.Notes))
                {
                    <div class="mb-4 p-3 rounded-3" style="background: var(--todo-bg); border: 1px solid var(--todo-border)">
                        <p class="small fw-semibold text-muted mb-1">NOTES</p>
                        <p class="mb-0">@Model.Notes</p>
                    </div>
                }

                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <div class="p-3 rounded-3 text-center" style="background: var(--todo-bg); border: 1px solid var(--todo-border)">
                            <p class="small fw-semibold text-muted mb-1">CREATED</p>
                            <p class="mb-0 fw-medium">@Model.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</p>
                            <p class="small text-muted mb-0">@Model.CreatedAt.ToLocalTime().ToString("h:mm tt")</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded-3 text-center" style="background: var(--todo-bg); border: 1px solid var(--todo-border)">
                            <p class="small fw-semibold text-muted mb-1">COMPLETED</p>
                            @if (Model.CompletedAt.HasValue)
                            {
                                <p class="mb-0 fw-medium">@Model.CompletedAt.Value.ToLocalTime().ToString("MMM d, yyyy")</p>
                                <p class="small text-muted mb-0">@Model.CompletedAt.Value.ToLocalTime().ToString("h:mm tt")</p>
                            }
                            else
                            {
                                <p class="mb-0 text-muted">—</p>
                            }
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-todo-primary">Edit</a>
                    <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:8px">← Back</a>
                </div>
            </div>
        </div>
    </div>
</div>
