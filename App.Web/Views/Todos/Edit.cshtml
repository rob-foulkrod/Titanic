@model App.Web.Models.TodoItem
@using App.Web.Models

@{
    ViewData["Title"] = "Edit Task";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="todo-card">
            <div class="todo-card-header">
                <h2 class="h4 mb-0 fw-bold">✏️ Edit Task</h2>
                <p class="mb-0 small text-muted mt-1">Update the details below.</p>
            </div>
            <div class="p-4">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Task Title <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Priority" class="form-label">Priority</label>
                        <select asp-for="Priority" class="form-select"
                                asp-items="Html.GetEnumSelectList<Priority>()"></select>
                        <span asp-validation-for="Priority" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label">Notes <span class="text-muted fw-normal small">(optional)</span></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Notes" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsCompleted" class="form-check-input" type="checkbox"
                                   style="width:2.5em; height:1.3em;" />
                            <label asp-for="IsCompleted" class="form-check-label fw-medium ms-2">Mark as Completed</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-todo-primary">Save Changes</button>
                        <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:8px">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
