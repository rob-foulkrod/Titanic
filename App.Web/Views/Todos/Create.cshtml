@model App.Web.Models.TodoItem
@using App.Web.Models

@{
    ViewData["Title"] = "New Task";
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="todo-card">
            <div class="todo-card-header">
                <h2 class="h4 mb-0 fw-bold">✨ New Task</h2>
                <p class="mb-0 small text-muted mt-1">What do you need to get done?</p>
            </div>
            <div class="p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Task Title <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" placeholder="e.g. Buy groceries" autofocus />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Priority" class="form-label">Priority</label>
                        <select asp-for="Priority" class="form-select"
                                asp-items="Html.GetEnumSelectList<Priority>()"></select>
                        <span asp-validation-for="Priority" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notes" class="form-label">Notes <span class="text-muted fw-normal small">(optional)</span></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"
                                  placeholder="Any extra details..."></textarea>
                        <span asp-validation-for="Notes" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-todo-primary">Add Task</button>
                        <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:8px">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
